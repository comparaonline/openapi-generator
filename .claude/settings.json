{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && yarn lint"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(yarn lint*)",
      "Bash(yarn check-code*)",
      "Bash(yarn test*)"
    ]
  }
}
